.DS_Store

# Python and local tools.
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.basedpyright/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Local agent, evidence, index, and runtime state.
.omo/
.codegraph/
.local/
.state/
state/
logs/
*.log
*.jsonl
evidence/
audit/

# Local env and credential material.
.env
.env.*
.envrc
*.env
*.pem
*.key
*.p12
*.pfx
*credential*
*credentials*
*secret*
*secrets*
*token*
*tokens*
*refresh*
*apikey*
*api-key*

# Source, tests, and CI may use auth/token words in file names; keep them reviewable.
!src/
!src/**
!tests/
!tests/**
!.github/
!.github/**
src/**/__pycache__/
src/**/*.py[cod]
tests/**/__pycache__/
tests/**/*.py[cod]
